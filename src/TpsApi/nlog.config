<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      internalLogLevel="Off"
      throwExceptions="false">

  <extensions>
    <add assembly="NLog.Web.AspNetCore"/>
  </extensions>

  <targets async="true">
    <target name="console" xsi:type="Console"
            layout="[${longdate}] [${level:uppercase=true}] [${logger}] [TraceId:${mdlc:TraceId}] ${message} ${exception:format=tostring}" />

    <target name="file" xsi:type="File"
            fileName="logs/tps-${shortdate}.log"
            layout="[${longdate}] [${level}] [${logger}] [TraceId:${mdlc:TraceId}] ${message} ${exception:format=tostring}"
            maxArchiveFiles="30"
            archiveAboveSize="10485760"
            archiveEvery="Day" />
  </targets>

  <rules>
    <logger name="Microsoft.*" maxlevel="Warning" final="true" />
    <logger name="System.*" maxlevel="Warning" final="true" />
    <logger name="*" minlevel="Info" writeTo="console,file" />
  </rules>
</nlog>
